generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- MODÈLES ---
// Suppression de @@schema("public") partout, car c'est le défaut.
// Suppression de multiSchema, car Supabase gère l'auth séparément.

model Evenement {
  id           String   @id @default(cuid())
  slug         String   @unique
  titre        String
  categorie    String
  date         DateTime
  heure        String?
  lieu         String
  ville        String?
  prix         String?
  capacite     String?
  organisateur String?
  description  String?
  image        String?
  badge        String?
  badgeColor   String?
  artistes     Json?
  duree        String?
  programme    Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("evenements")
}

model EvenementPrestation {
  id          String   @id @default(cuid())
  label       String
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("evenement_prestations")
}

model RdvInscription {
  id             String   @id @default(cuid())
  reference      String   @unique
  clientName     String
  clientPhone    String
  clientEmail    String?
  evenementSlug  String
  evenementTitre String?
  evenementDate  String?
  evenementLieu  String?
  participants   Int      @default(1)
  message        String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("rdv_inscriptions")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String?
  firstName        String
  lastName         String
  phone            String?
  whatsapp         String?
  nationality      String?
  role             Role     @default(CLIENT)
  emailVerified    Boolean  @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  equipmentRentals  EquipmentRental[]
  eventRequests     EventRequest[]
  excursionBookings ExcursionBooking[]
  hotelBookings     HotelBooking[]
  mediaRequests     MediaAdRequest[]
  musicBookings     MusicBooking[]
  notifications     Notification[]
  payments          Payment[]
  reviews           Review[]
  studioBookings    StudioBooking[]

  @@map("users")
}

// ... (Garde tous tes autres modèles de la même manière, SANS @@schema et SANS @@map s'ils n'en ont pas besoin)

model VilleContenu {
  id          String   @id @default(cuid())
  ville       String
  categorie   String
  nom         String
  description String?
  adresse     String?
  telephone   String?
  whatsapp    String?
  siteWeb     String?
  image       String?
  prix        String?
  note        Float?
  
  partner_id  String?  // Garde ce champ pour le RLS
  
  isTopDestination Boolean @default(false)
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ville, categorie])
  @@index([partner_id])
  @@map("ville_contenus")
}

// --- ENUMS (Pas besoin de @@schema ici non plus) ---
enum Role {
  CLIENT
  ADMIN
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUSED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  CONFIRMED
}

enum PaymentMethod {
  ORANGE_MONEY
  MTN_MONEY
  MOOV_MONEY
  WAVE
  CASH
  BANK_TRANSFER
}

enum NotificationType {
  EMAIL
  SMS
  INTERNAL
}