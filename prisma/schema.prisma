generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODÈLES CORRIGÉS & AJOUTÉS ---

model Evenement {
  id           String   @id @default(cuid())
  slug         String   @unique
  titre        String
  categorie    String
  date         DateTime
  heure        String?
  lieu         String
  ville        String?
  prix         String?
  capacite     String?
  organisateur String?
  description  String?
  image        String?
  badge        String?
  badgeColor   String?
  artistes     Json?
  duree        String?
  programme    Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("evenements")
}

// NOUVEAU MODÈLE AJOUTÉ ICI
model EvenementPrestation {
  id          String   @id @default(cuid())
  label       String
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("evenement_prestations")
}

model RdvInscription {
  id             String   @id @default(cuid())
  reference      String   @unique
  clientName     String
  clientPhone    String
  clientEmail    String?
  evenementSlug  String
  evenementTitre String?
  evenementDate  String?
  evenementLieu  String?
  participants   Int      @default(1)
  message        String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("rdv_inscriptions")
}

// --- UTILISATEURS & AUTH ---
model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String?
  firstName        String
  lastName         String
  phone            String?
  whatsapp         String?
  nationality      String?
  role             Role              @default(CLIENT)
  emailVerified    Boolean           @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  equipmentRentals EquipmentRental[]
  eventRequests    EventRequest[]
  excursionBookings ExcursionBooking[]
  hotelBookings    HotelBooking[]
  mediaRequests    MediaAdRequest[]
  musicBookings    MusicBooking[]
  notifications    Notification[]
  payments         Payment[]
  reviews          Review[]
  studioBookings   StudioBooking[]

  @@map("users")
}

// --- OPPORTUNITÉS & SERVICES ---
model OpportuniteSecteur {
  id          String   @id @default(cuid())
  nom         String
  categorie   String
  couleur     String
  description String
  image       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("opportunite_secteurs")
}

model CollectiviteService {
  id          String   @id @default(cuid())
  nom         String
  categorie   String
  description String
  image       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("collectivite_services")
}

model CollectiviteAnnuaire {
  id        String   @id @default(cuid())
  nom       String
  type      String
  ville     String
  region    String
  telephone String?
  email     String?
  adresse   String?
  siteWeb   String?
  horaires  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("collectivite_annuaire")
}

model AfroubaSupport {
  id          String   @id @default(cuid())
  nom         String
  categorie   String
  description String
  prix        String   @default("Sur devis")
  image       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("afrouba_supports")
}

// --- BOOKINGS & RESERVATIONS ---
model StudioBooking {
  id                String        @id @default(cuid())
  reference         String        @unique
  userId            String?
  clientFirstName   String
  clientLastName    String
  clientEmail       String
  clientPhone       String
  clientWhatsapp    String?
  clientAddress     String?
  eventType         String
  eventDate         DateTime
  eventTimeSlot     String
  eventLocation     String
  eventDuration     String
  guestCount        Int?
  description       String?
  services          String[]
  attachments       String[]
  estimatedPriceMin Int?
  estimatedPriceMax Int?
  status            BookingStatus @default(PENDING)
  adminNotes        String?
  quotePdfUrl       String?
  paymentStatus     PaymentStatus @default(UNPAID)
  depositAmount     Int?
  totalAmount       Int?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  notifications     Notification[]
  payments          Payment[]
  user              User?         @relation(fields: [userId], references: [id])

  @@map("studio_bookings")
}

model Excursion {
  id              String              @id @default(cuid())
  title           String
  slug            String              @unique
  description     String
  duration        String
  difficulty      String?
  maxParticipants Int                 @default(20)
  priceAdult      Int
  priceChild      Int
  images          String[]
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  bookings        ExcursionBooking[]
  options         ExcursionOption[]
  timeSlots       ExcursionTimeSlot[]
  reviews         Review[]

  @@map("excursions")
}

model ExcursionOption {
  id             String    @id @default(cuid())
  excursionId    String
  label          String
  pricePerPerson Int
  isActive       Boolean   @default(true)
  excursion      Excursion @relation(fields: [excursionId], references: [id])

  @@map("excursion_options")
}

model ExcursionTimeSlot {
  id          String    @id @default(cuid())
  excursionId String
  startTime   String
  endTime     String
  isActive    Boolean   @default(true)
  excursion   Excursion @relation(fields: [excursionId], references: [id])

  @@map("excursion_time_slots")
}

model ExcursionAvailability {
  id          String   @id @default(cuid())
  excursionId String
  date        DateTime @db.Date
  timeSlot    String
  totalSlots  Int
  bookedSlots Int      @default(0)
  isBlocked   Boolean  @default(false)
  blockReason String?

  @@unique([excursionId, date, timeSlot])
  @@map("excursion_availability")
}

model ExcursionBooking {
  id                 String        @id @default(cuid())
  reference          String        @unique
  excursionId        String
  userId             String?
  clientFirstName    String
  clientLastName     String
  clientEmail        String
  clientPhone        String
  clientNationality  String?
  bookingDate        DateTime      @db.Date
  timeSlot           String
  guideLanguage      String        @default("FR")
  adultsCount        Int
  childrenCount      Int           @default(0)
  specialRequests    String?
  conditionsAccepted Boolean       @default(false)
  selectedOptions    Json?
  adultsTotal        Int
  childrenTotal      Int
  optionsTotal       Int           @default(0)
  totalAmount        Int
  status             BookingStatus @default(PENDING)
  voucherPdfUrl      String?
  adminNotes         String?
  paymentStatus      PaymentStatus @default(UNPAID)
  depositAmount      Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  excursion          Excursion     @relation(fields: [excursionId], references: [id])
  user               User?         @relation(fields: [userId], references: [id])
  notifications      Notification[]
  payments           Payment[]

  @@map("excursion_bookings")
}

model Equipment {
  id           String                @id @default(cuid())
  name         String
  slug         String                @unique
  description  String?
  category     String
  totalStock   Int
  pricePerDay  Int
  depositValue Int
  images       String[]
  techSheetUrl String?
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  rentalItems  EquipmentRentalItem[]

  @@map("equipment")
}

model EquipmentRental {
  id              String                @id @default(cuid())
  reference       String                @unique
  userId          String?
  clientFirstName String
  clientLastName  String
  clientEmail     String
  clientPhone     String
  startDate       DateTime              @db.Date
  endDate         DateTime              @db.Date
  daysCount       Int
  deliveryAddress String?
  selfPickup      Boolean               @default(false)
  withDelivery    Boolean               @default(false)
  withInstall     Boolean               @default(false)
  withInsurance   Boolean               @default(false)
  equipmentTotal  Int
  optionsTotal    Int                   @default(0)
  insuranceAmount Int                   @default(0)
  depositAmount   Int
  totalAmount     Int
  status          BookingStatus         @default(PENDING)
  returnStatus    String?
  returnDate      DateTime?
  penaltyAmount   Int?
  contractPdfUrl  String?
  adminNotes      String?
  paymentStatus   PaymentStatus         @default(UNPAID)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  items           EquipmentRentalItem[]
  user            User?                 @relation(fields: [userId], references: [id])
  notifications   Notification[]
  payments        Payment[]

  @@map("equipment_rentals")
}

model EquipmentRentalItem {
  id          String          @id @default(cuid())
  rentalId    String
  equipmentId String
  quantity    Int
  pricePerDay Int
  subtotal    Int
  equipment   Equipment       @relation(fields: [equipmentId], references: [id])
  rental      EquipmentRental @relation(fields: [rentalId], references: [id])

  @@map("equipment_rental_items")
}

model Room {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  description   String?
  type          String
  capacity      Int
  pricePerNight Int
  images        String[]
  amenities     String[]
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  bookings      HotelBooking[]
  availability  RoomAvailability[]

  @@map("rooms")
}

model RoomAvailability {
  id        String   @id @default(cuid())
  roomId    String
  date      DateTime @db.Date
  isBlocked Boolean  @default(false)
  price     Int?
  room      Room     @relation(fields: [roomId], references: [id])

  @@unique([roomId, date])
  @@map("room_availability")
}

model HotelBooking {
  id              String         @id @default(cuid())
  reference       String         @unique
  roomId          String
  userId          String?
  clientFirstName String
  clientLastName  String
  clientEmail     String
  clientPhone     String
  checkIn         DateTime       @db.Date
  checkOut        DateTime       @db.Date
  nightsCount     Int
  guestsCount     Int
  mealPlan        String?
  roomTotal       Int
  mealTotal       Int            @default(0)
  totalAmount     Int
  status          BookingStatus  @default(PENDING)
  voucherPdfUrl   String?
  adminNotes      String?
  paymentStatus   PaymentStatus  @default(UNPAID)
  depositAmount   Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  room            Room           @relation(fields: [roomId], references: [id])
  user            User?          @relation(fields: [userId], references: [id])
  notifications   Notification[]
  payments        Payment[]

  @@map("hotel_bookings")
}

model MusicBooking {
  id                 String         @id @default(cuid())
  reference          String         @unique
  userId             String?
  clientFirstName    String
  clientLastName     String
  clientEmail        String
  clientPhone        String
  artistName         String?
  projectDescription String?
  demoUrl            String?
  sessionDate        DateTime
  sessionDuration    String
  serviceType        String
  totalAmount        Int?
  status             BookingStatus  @default(PENDING)
  adminNotes         String?
  paymentStatus      PaymentStatus  @default(UNPAID)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User?          @relation(fields: [userId], references: [id])
  notifications      Notification[]
  payments           Payment[]

  @@map("music_bookings")
}

model EventRequest {
  id              String         @id @default(cuid())
  reference       String         @unique
  userId          String?
  clientFirstName String
  clientLastName  String
  clientEmail     String
  clientPhone     String
  eventType       String
  eventDate       DateTime
  eventLocation   String
  guestCount      Int
  budget          String?
  services        String[]
  attachments     String[]
  description     String?
  status          BookingStatus  @default(PENDING)
  quotePdfUrl     String?
  adminNotes      String?
  paymentStatus   PaymentStatus  @default(UNPAID)
  totalAmount     Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User?          @relation(fields: [userId], references: [id])
  notifications   Notification[]
  payments        Payment[]

  @@map("event_requests")
}

model MediaAdRequest {
  id           String         @id @default(cuid())
  reference    String         @unique
  userId       String?
  clientName   String
  clientEmail  String
  clientPhone  String
  companyName  String?
  mediaType    String
  adType       String
  duration     String?
  startDate    DateTime?
  endDate      DateTime?
  budget       String?
  description  String?
  status       BookingStatus  @default(PENDING)
  quotePdfUrl  String?
  adminNotes   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User?          @relation(fields: [userId], references: [id])
  notifications Notification[]

  @@map("media_ad_requests")
}

model AfroubaRequest {
  id              String        @id @default(cuid())
  reference       String        @unique
  clientFirstName String
  clientLastName  String
  clientEmail     String
  clientPhone     String
  documentType    String
  attachments     String[]
  description     String?
  status          BookingStatus @default(PENDING)
  adminNotes      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("afrouba_requests")
}

model Payment {
  id                 String           @id @default(cuid())
  reference          String           @unique
  userId             String?
  amount             Int
  method             PaymentMethod
  status             PaymentStatus    @default(UNPAID)
  transactionId      String?
  phoneNumber        String?
  studioBookingId    String?
  excursionBookingId String?
  equipmentRentalId  String?
  hotelBookingId     String?
  musicBookingId     String?
  eventRequestId     String?
  receiptPdfUrl      String?
  paidAt             DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  equipmentRental    EquipmentRental? @relation(fields: [equipmentRentalId], references: [id])
  eventRequest       EventRequest?    @relation(fields: [eventRequestId], references: [id])
  excursionBooking   ExcursionBooking? @relation(fields: [excursionBookingId], references: [id])
  hotelBooking       HotelBooking?    @relation(fields: [hotelBookingId], references: [id])
  musicBooking       MusicBooking?    @relation(fields: [musicBookingId], references: [id])
  studioBooking      StudioBooking?   @relation(fields: [studioBookingId], references: [id])
  user               User?            @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Notification {
  id                 String           @id @default(cuid())
  userId             String?
  type               NotificationType
  subject            String
  content            String
  isRead             Boolean          @default(false)
  sentAt             DateTime?
  studioBookingId    String?
  excursionBookingId String?
  equipmentRentalId  String?
  hotelBookingId     String?
  musicBookingId     String?
  eventRequestId     String?
  mediaRequestId     String?
  createdAt          DateTime         @default(now())
  equipmentRental    EquipmentRental? @relation(fields: [equipmentRentalId], references: [id])
  eventRequest       EventRequest?    @relation(fields: [eventRequestId], references: [id])
  excursionBooking   ExcursionBooking? @relation(fields: [excursionBookingId], references: [id])
  hotelBooking       HotelBooking?    @relation(fields: [hotelBookingId], references: [id])
  mediaRequest       MediaAdRequest?  @relation(fields: [mediaRequestId], references: [id])
  musicBooking       MusicBooking?    @relation(fields: [musicBookingId], references: [id])
  studioBooking      StudioBooking?   @relation(fields: [studioBookingId], references: [id])
  user               User?            @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Review {
  id          String     @id @default(cuid())
  userId      String
  excursionId String?
  serviceType String
  rating      Int
  comment     String?
  isApproved  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  excursion   Excursion? @relation(fields: [excursionId], references: [id])
  user        User       @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model MarketProduit {
  id        String   @id @default(cuid())
  label     String
  desc      String?
  prix      Int
  unite     String
  categorie String
  images    String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketProduit")
}

model BlockedDate {
  id          String   @id @default(cuid())
  serviceType String
  serviceId   String?
  date        DateTime @db.Date
  reason      String?
  createdAt   DateTime @default(now())

  @@map("blocked_dates")
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("text")
  updatedAt DateTime @updatedAt

  @@map("site_content")
}

// LE MODÈLE INFOPRESTATION FINAL SANS DOUBLON
model InfoPrestation {
  id          String   @id @default(cuid())
  nom         String
  categorie   String?
  description String?
  prix        String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("info_prestations")
}

model VilleContenu {
  id          String   @id @default(cuid())
  ville       String
  categorie   String
  nom         String
  description String?
  adresse     String?
  telephone   String?
  whatsapp    String?
  siteWeb     String?
  image       String?
  prix        String?
  note        Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ville, categorie])
  @@map("ville_contenus")
}

// --- ENUMS ---
enum Role {
  CLIENT
  ADMIN
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUSED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  ORANGE_MONEY
  MTN_MONEY
  MOOV_MONEY
  WAVE
  CASH
  BANK_TRANSFER
}

enum NotificationType {
  EMAIL
  SMS
  INTERNAL
}