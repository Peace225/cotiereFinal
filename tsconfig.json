{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/components/admin/*": ["./admin/*"],
      "@/components/admin/AdminNavbar": ["./admin/AdminNavbar"],
      "@/components/admin/DevisButton": ["./admin/DevisButton"],
      "@/components/admin/ExportButton": ["./admin/ExportButton"],
      "@/components/admin/ImageUploader": ["./admin/ImageUploader"],
      "@/components/admin/NotificationBell": ["./admin/NotificationBell"],
      "@/components/admin/ReceiptButton": ["./admin/ReceiptButton"],
      "@/components/admin/VoucherButton": ["./admin/VoucherButton"],
      "@/components/frontend/home/*": ["./frontend/components/home/*"],
      "@/components/frontend/layout/*": ["./frontend/components/layout/*"],
      "@/components/frontend/studio/*": ["./frontend/components/studio/*"],
      "@/components/frontend/excursions/*": ["./frontend/components/excursions/*"],
      "@/components/frontend/events/*": ["./frontend/components/events/*"],
      "@/components/frontend/events/PrestationsSection": ["./frontend/components/events/PrestationsSection"],
      "@/components/frontend/CartContext": ["./frontend/components/CartContext"],
      "@/components/frontend/ReviewsSection": ["./frontend/components/ReviewsSection"],
      "@/components/frontend/ReservationModal": ["./frontend/components/ReservationModal"],
      "@/components/frontend/ImageZoom": ["./frontend/components/ImageZoom"],
      "@/components/frontend/AvailabilityCalendar": ["./frontend/components/AvailabilityCalendar"],
      "@/components/frontend/PaymentModal": ["./frontend/components/PaymentModal"],
      "@/components/frontend/EventRequestForm": ["./frontend/components/EventRequestForm"],
      "@/components/ui/*": ["./frontend/ui/*"],
      "@/components/Providers": ["./frontend/Providers"],
      "@/lib/*": ["./lib/*"],
      "@/components/HeroSection": ["./frontend/components/HeroSection"],
      "@/components/ResultatsRecherche": ["./frontend/components/ResultatsRecherche"],
      "@/components/SectionGrid": ["./frontend/components/SectionGrid"],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
